# Firebase web app config — copy to `.env` and fill in from the Firebase console
# (Project settings → General → Your apps → SDK setup and configuration).
# These are public client keys (safe to ship); real protection comes from RTDB Security Rules.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Set to "1" to connect to local Firebase emulators (Auth + RTDB) instead of the live project.
VITE_USE_EMULATORS=
